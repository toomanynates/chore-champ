// Firestore Security Rules for Chore Champ
// TEMPORARY: Allow all authenticated users full access for debugging
// In production, replace with more restrictive rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all authenticated users to read and write everything
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
