// Firestore Security Rules for Chore Champ
// Deploy these rules to your Firebase project via Firebase Console or Firebase CLI

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is a parent or child
    function isParent(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'parent';
    }

    function isChild(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'child';
    }

    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Tasks collection - parents can read/write, children can only read assigned tasks
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        (isChild(request.auth.uid) && request.auth.uid in resource.data.assignedChildrenIds)
      );
      allow create: if isAuthenticated() && isParent(request.auth.uid);
      allow update: if isAuthenticated() && resource.data.parentId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.parentId == request.auth.uid;
    }

    // Task completions - children can create, parents can read/update
    match /taskCompletions/{completionId} {
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.childId;
      allow read: if isAuthenticated() && (
        resource.data.childId == request.auth.uid ||
        isParent(request.auth.uid)
      );
      allow update: if isAuthenticated() && isParent(request.auth.uid);
    }

    // Ledger - children can read their own, parents can read/write
    match /ledger/{entryId} {
      allow read: if isAuthenticated() && (
        resource.data.childId == request.auth.uid ||
        isParent(request.auth.uid)
      );
      allow create: if isAuthenticated() && isParent(request.auth.uid);
      allow update: if isAuthenticated() && isParent(request.auth.uid);
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
